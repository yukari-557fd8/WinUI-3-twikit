<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="App2.Controls.QuotedTweetCard"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App2"
    xmlns:controls="using:App2.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <local:InverseBoolConverter x:Key="InverseBoolConverter" />
        <local:MediaTypeToVisibilityConverter x:Key="MediaTypeToVisibilityConverter" />
    </UserControl.Resources>

    <Border x:Name="QuoteBorder"
            BorderBrush="#2A2A2A"
            BorderThickness="1"
            CornerRadius="12"
            Padding="12"
            Background="#1A1A1A"
            IsHitTestVisible="{Binding QuotedTweet.IsUnavailable, Converter={StaticResource InverseBoolConverter}}"
            PointerEntered="QuoteBorder_PointerEntered"
            PointerExited="QuoteBorder_PointerExited"
            Tapped="QuoteBorder_Tapped">
        <StackPanel Spacing="12">
            <controls:TweetUserRow
                Visibility="{Binding QuotedTweet.IsUnavailable, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                UserName="{Binding QuotedTweet.UserName}"
                UserScreenName="{Binding QuotedTweet.UserScreenName}"
                CreatedAtAbsoluteDisplay="{Binding QuotedTweet.CreatedAtAbsoluteDisplay}"
                CreatedAtRelativeDisplay="{Binding QuotedTweet.CreatedAtRelativeDisplay}"
                UserProfileImage="{Binding QuotedTweet.UserProfileImage}"/>

            <TextBlock Text="{Binding QuotedTweet.Text}"
                       FontSize="15"
                       LineHeight="20"
                       TextWrapping="WrapWholeWords"
                       Visibility="{Binding QuotedTweet.IsUnavailable, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

            <ItemsControl ItemsSource="{Binding QuotedCardMediaItems}"
                          Visibility="{Binding QuotedCardHasMedia, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:MediaItem">
                        <Border CornerRadius="8"
                                Background="#1A1A1A"
                                Margin="0,4"
                                MaxWidth="280"
                                HorizontalAlignment="Left">
                            <Grid HorizontalAlignment="Left"
                                  MinWidth="120"
                                  MinHeight="80">
                                <Image Source="{x:Bind ThumbnailImage, Mode=OneTime}"
                                       Tag="{x:Bind Url, Mode=OneTime}"
                                       Stretch="Uniform"
                                       MaxHeight="160"
                                       HorizontalAlignment="Left"
                                       Tapped="MediaThumbnail_Tapped"/>
                                <Border Background="#80000000"
                                        CornerRadius="32"
                                        Width="64" Height="64"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False"
                                        Visibility="{x:Bind Type, Converter={StaticResource MediaTypeToVisibilityConverter}, ConverterParameter=video}">
                                    <FontIcon Glyph="&#xE768;" FontSize="28" Foreground="White"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="このツイートは表示できません"
                       FontStyle="Italic"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Visibility="{Binding QuotedTweet.IsUnavailable, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>
    </Border>
</UserControl>