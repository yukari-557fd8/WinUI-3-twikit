<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="App2.Controls.TweetUserRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <PersonPicture Grid.Column="0"
                       Width="48"
                       Height="48"
                       VerticalAlignment="Center"
                       ProfilePicture="{x:Bind UserProfileImage, Mode=OneWay}"/>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="6">
            <TextBlock Text="{x:Bind UserName, Mode=OneWay}"
                       FontSize="15"
                       LineHeight="20"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{x:Bind UserScreenName, Mode=OneWay}"
                       FontSize="15"
                       LineHeight="20"
                       FontWeight="Light"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{x:Bind CreatedAtAbsoluteDisplay, Mode=OneWay}"
                       FontSize="15"
                       LineHeight="20"
                       FontWeight="Light"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="・"
                       FontSize="15"
                       LineHeight="20"
                       FontWeight="Light"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{x:Bind CreatedAtRelativeDisplay, Mode=OneWay}"
                       FontSize="15"
                       LineHeight="20"
                       FontWeight="Light"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
