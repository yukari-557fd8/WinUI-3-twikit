<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App2.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <local:HasItemsToVisibilityConverter x:Key="HasItemsToVisibilityConverter" />
        <local:LikeColorConverter x:Key="LikeColorConverter" />
        <local:RetweetColorConverter x:Key="RetweetColorConverter" />
        <local:MediaTypeToVisibilityConverter x:Key="MediaTypeToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 検索バー（横幅に合わせて自動調整） -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- 検索ボックスが伸縮 -->
                <ColumnDefinition Width="Auto"/>
                <!-- ボタンは固定 -->
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     PlaceholderText="検索"
                     KeyDown="SearchBox_KeyDown"
                     VerticalAlignment="Center"
                     MinWidth="200"
                     Margin="0,0,8,0"/>

            <Button Grid.Column="1"
                    Content="検索"
                    Click="SearchButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Width="100"/>
        </Grid>

        <!-- 読み込み中 -->
        <ProgressRing Grid.Row="1"
                      Width="60" Height="60"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>

        <!-- 検索結果 -->
        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}"
                  x:Name="SearchListView"
                  SelectionMode="None"
                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:TweetViewModel">
                    <Border Margin="0,6" Padding="16" CornerRadius="12"
                            Background="#1F1F1F" BorderBrush="#2A2A2A" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <PersonPicture Width="48" Height="48" ProfilePicture="{x:Bind UserProfileImage, Mode=OneWay}"/>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind UserName}" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="15"/>
                                    <TextBlock Text="{x:Bind UserScreenName}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind CreatedAt}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="{x:Bind Text}" TextWrapping="WrapWholeWords" FontSize="15" LineHeight="20"/>

                            <!-- メディア (画像 + 動画対応) -->
                            <ItemsControl ItemsSource="{x:Bind MediaItems, Mode=OneWay}"
                                              Visibility="{x:Bind MediaItems, Converter={StaticResource HasItemsToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:MediaItem">
                                        <Border CornerRadius="8" Background="#1A1A1A" Margin="0,4" MaxWidth="320">
                                            <Grid>
                                                <Image Source="{x:Bind ThumbnailImage, Mode=OneTime}"
                                                       Tag="{x:Bind Url, Mode=OneTime}"
                                                       Stretch="Uniform"
                                                       MaxHeight="260"
                                                       HorizontalAlignment="Center"
                                                       Tapped="MediaThumbnail_Tapped"/>
                                                <Border Background="#80000000"
                                                        CornerRadius="32"
                                                        Width="64" Height="64"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        IsHitTestVisible="False"
                                                        Visibility="{x:Bind Type, Converter={StaticResource MediaTypeToVisibilityConverter}, ConverterParameter=video}">
                                                    <FontIcon Glyph="&#xE768;" FontSize="28" Foreground="White"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Left" Margin="0,8,0,0">
                                <Button Style="{StaticResource SubtleButtonStyle}" Click="ReplyButton_Click" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8BD;" FontSize="18"/>
                                        <TextBlock Text="{x:Bind ReplyCount}"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SubtleButtonStyle}" Click="RetweetButton_Click" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE72A;" FontSize="18" Foreground="{x:Bind IsRetweeted, Converter={StaticResource RetweetColorConverter}}"/>
                                        <TextBlock Text="{x:Bind RetweetCount}"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SubtleButtonStyle}" Click="LikeButton_Click" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xEB51;" FontSize="18" Foreground="{x:Bind IsLiked, Converter={StaticResource LikeColorConverter}}"/>
                                        <TextBlock Text="{x:Bind FavoriteCount}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <!-- 返信フォーム（IsReplying が true のときだけ表示） -->
                            <StackPanel Visibility="{x:Bind IsReplying, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="8" Margin="0,8,0,0">
                                <TextBox Text="{x:Bind ReplyText, Mode=TwoWay}" 
             PlaceholderText="返信を入力..." 
             AcceptsReturn="True" 
             TextWrapping="Wrap"
             MaxHeight="120"
             VerticalAlignment="Top"/>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="返信" 
                Click="SendReply_Click"
                Style="{StaticResource AccentButtonStyle}"/>
                                    <Button Content="キャンセル" 
                Click="CancelReply_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>