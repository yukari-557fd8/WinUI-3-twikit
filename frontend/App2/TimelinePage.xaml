<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App2.TimelinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <local:HasItemsToVisibilityConverter x:Key="HasItemsToVisibilityConverter" />
        <local:LikeColorConverter x:Key="LikeColorConverter" />
        <local:RetweetColorConverter x:Key="RetweetColorConverter" />
        <local:MediaTypeToVisibilityConverter x:Key="MediaTypeToVisibilityConverter" />
        <local:StringToBitmapImageConverter x:Key="StringToBitmapImageConverter" />
    </Page.Resources>

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 自動更新コントロール -->
            <RowDefinition Height="Auto"/>
            <!-- タブ -->
            <RowDefinition Height="*"/>
            <!-- タイムライン -->
        </Grid.RowDefinitions>

        <!-- 1. 自動更新コントロール -->
        <StackPanel Orientation="Horizontal"
            Spacing="16"
            VerticalAlignment="Center"
            Margin="12,8,12,1"
            Grid.Row="0">

            <!-- 自動更新ヘッダー -->
            <TextBlock Text="自動更新"
               VerticalAlignment="Center"
               FontSize="14"/>

            <!-- ON/OFF ボタン -->
            <ToggleSwitch x:Name="AutoUpdateToggle"
                  OnContent="ON"
                  OffContent="OFF"
                  Toggled="AutoUpdateToggle_Toggled"
                  IsOn="False"
                  VerticalAlignment="Center"/>

            <!-- 間隔(秒) + NumberBox -->
            <StackPanel Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center">

                <TextBlock Text="間隔(秒)"
                   VerticalAlignment="Center"
                   FontSize="14"/>

                <NumberBox x:Name="PollingIntervalBox"
                   Value="15"
                   Minimum="5"
                   Maximum="300"
                   Width="80"
                   SpinButtonPlacementMode="Hidden"
                   SmallChange="5"/>
            </StackPanel>
        </StackPanel>

        <!-- 2. タブ（おすすめ / 最新） -->
        <TabView x:Name="TimelineTabView" 
                 TabWidthMode="SizeToContent" 
                 SelectedIndex="0" 
                 SelectionChanged="TimelineTabView_SelectionChanged"
                 Margin="12,1,12,4"
                 Grid.Row="1">
            <TabView.TabItems>
                <TabViewItem Header="おすすめ" Tag="for_you" />
                <TabViewItem Header="最新" Tag="latest" />
            </TabView.TabItems>
        </TabView>

        <!-- 3. 読み込み中 -->
        <ProgressRing
            Width="60" Height="60"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Grid.Row="2"
            IsIndeterminate="True"/>

        <!-- 4. タイムライン -->
        <ListView ItemsSource="{x:Bind ViewModel.Tweets, Mode=OneWay}"
                  SelectionMode="None"
                  Padding="8"
                  x:Name="TimelineListView"
                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                  Grid.Row="2"
                  Margin="0,0,0,0">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:TweetViewModel">
                    <StackPanel>
                        <!-- ツイート本体カード -->
                        <Border Margin="0,6" Padding="16" CornerRadius="12"
                                Background="#1F1F1F" BorderBrush="#2A2A2A" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <!-- ユーザー情報 -->
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <PersonPicture Width="48" Height="48" ProfilePicture="{x:Bind UserProfileImage, Mode=OneWay}"/>
                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind UserName}" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="15"/>
                                        <TextBlock Text="{x:Bind UserScreenName}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind CreatedAt}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 本文 -->
                                <TextBlock Text="{x:Bind Text}" TextWrapping="WrapWholeWords" FontSize="15" LineHeight="20"/>

                                <!-- メディア -->
                                <ItemsControl ItemsSource="{x:Bind MediaItems, Mode=OneWay}"
                                              Visibility="{x:Bind MediaItems, Converter={StaticResource HasItemsToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:MediaItem">
                                            <Border CornerRadius="8" Background="#1A1A1A" Margin="0,4" MaxWidth="320">
                                                <Grid>
                                                    <Image Source="{x:Bind ThumbnailImage, Mode=OneTime}"
                                                           Tag="{x:Bind Url, Mode=OneTime}"
                                                           Stretch="Uniform"
                                                           MaxHeight="260"
                                                           HorizontalAlignment="Center"
                                                           Tapped="MediaThumbnail_Tapped"/>
                                                    <Border Background="#80000000"
                                                            CornerRadius="32"
                                                            Width="64" Height="64"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            IsHitTestVisible="False"
                                                            Visibility="{x:Bind Type, Converter={StaticResource MediaTypeToVisibilityConverter}, ConverterParameter=video}">
                                                        <FontIcon Glyph="&#xE768;" FontSize="28" Foreground="White"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- アクションボタン -->
                                <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Left" Margin="0,8,0,0">
                                    <Button Style="{StaticResource SubtleButtonStyle}" Click="ReplyButton_Click" Padding="8,4">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE8BD;" FontSize="18" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind ReplyCount, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SubtleButtonStyle}" Click="RetweetButton_Click" Padding="8,4">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE72A;" FontSize="18" Foreground="{x:Bind IsRetweeted, Converter={StaticResource RetweetColorConverter}, Mode=OneWay}"/>
                                            <TextBlock Text="{x:Bind RetweetCount, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SubtleButtonStyle}" Click="LikeButton_Click" Padding="8,4">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xEB51;" FontSize="18" Foreground="{x:Bind IsLiked, Converter={StaticResource LikeColorConverter}, Mode=OneWay}"/>
                                            <TextBlock Text="{x:Bind FavoriteCount, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- リプライ入力 -->
                        <Border Visibility="{x:Bind IsReplying, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,8,0,20" Padding="16" CornerRadius="12"
                                Background="#1F1F1F" BorderBrush="#2A2A2A" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="このツイートに返信" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <Border Background="#252525" CornerRadius="8" Padding="12">
                                    <TextBox Text="{x:Bind ReplyText, Mode=TwoWay}" PlaceholderText="返信を入力..." AcceptsReturn="True" TextWrapping="Wrap" MinHeight="110" BorderThickness="0" Background="Transparent"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                    <Button Content="キャンセル" Click="CancelReply_Click" Style="{StaticResource SubtleButtonStyle}"/>
                                    <Button Content="リプライを送信" Click="SendReply_Click" Style="{StaticResource AccentButtonStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
