<?xml version="1.0" encoding="utf-8"?>
<win:Window
    x:Class="App2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App2"
    xmlns:win="using:Microsoft.UI.Xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:backdrop="using:Microsoft.UI.Xaml.Media"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinUI 3 Twitter">

    <win:Window.SystemBackdrop>
        <backdrop:MicaBackdrop />
    </win:Window.SystemBackdrop>

    <muxc:Grid>
        <muxc:NavigationView x:Name="NavView" 
                             ItemInvoked="NavView_ItemInvoked" 
                             PaneDisplayMode="Left" 
                             IsSettingsVisible="False">
            
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="ツイート" Icon="Edit" Tag="home" />
                <muxc:NavigationViewItem Content="ホーム" Icon="Home" Tag="timeline" />
                <muxc:NavigationViewItem Content="検索" Icon="Find" Tag="search" />
                <muxc:NavigationViewItem Content="通知" Icon="Message" Tag="notifications" />
                <muxc:NavigationViewItem Content="リスト" Icon="List" Tag="lists" />
                <muxc:NavigationViewItem Content="プロフィール" Icon="Account" Tag="myprofile" />
                <muxc:NavigationViewItem Content="設定" Icon="Setting" Tag="settings" />
            </muxc:NavigationView.MenuItems>

            <!-- PaneFooter（読み込み中をサーバー/時計の上に配置） -->
            <muxc:NavigationView.PaneFooter>
                <StackPanel Padding="12" Spacing="8">
                    
                    <!-- 読み込み中インジケーター -->
                    <StackPanel x:Name="LoadingPanel"
                                Orientation="Horizontal"
                                Spacing="8"
                                Visibility="Collapsed">
                        <ProgressRing Width="16" Height="16" IsIndeterminate="True" />
                        <TextBlock Text="読み込み中…"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- 取得ツイート数 -->
                    <TextBlock x:Name="ForYouTweetCountText"
                               FontFamily="Cascadia Mono"
                               FontSize="14"
                               HorizontalAlignment="Left"
                               Text="おすすめ: 0"/>
                    <TextBlock x:Name="LatestTweetCountText"
                               FontFamily="Cascadia Mono"
                               FontSize="14"
                               HorizontalAlignment="Left"
                               Text="最新: 0"/>

                    <!-- サーバーステータス -->
                    <TextBlock x:Name="ServerStatusText"
                               FontFamily="Cascadia Mono"
                               FontSize="14"
                               HorizontalAlignment="Left"
                               Text="API Server: Checking..."/>

                    <!-- 時計 -->
                    <TextBlock x:Name="ClockText"
                               FontFamily="Cascadia Mono"
                               FontSize="16"
                               HorizontalAlignment="Left"/>
                </StackPanel>
            </muxc:NavigationView.PaneFooter>

            <muxc:Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </muxc:Grid>
</win:Window>
