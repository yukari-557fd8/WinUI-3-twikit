<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App2.TweetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:HasItemsToVisibilityConverter x:Key="HasItemsToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="20" RowDefinitions="Auto,*">
        <TextBlock Text="ツイート" FontSize="24" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Spacing="12">
            <TextBox x:Name="InputBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="180"
                     TextChanged="InputBox_TextChanged"
                     PlaceholderText="いまどうしてる？">
                <TextBox.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="InputBox_CtrlEnterInvoked"/>
                </TextBox.KeyboardAccelerators>
            </TextBox>

            <!-- ツイートボタンエリア -->
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" Margin="0,12,0,0">
                <!-- ツイートボタン -->
                <Button x:Name="SendButton"
            Content="ツイートする"
            Click="OnSendClick"
            Grid.Column="0"
            Style="{StaticResource AccentButtonStyle}"
            Margin="0,0,8,0"
            IsEnabled="True"/>

                <!-- メディア追加ボタン -->
                <Button Content="📎 メディア追加" 
            Click="OnAddMediaClick"
            Grid.Column="1"
            Margin="0,0,8,0"/>

                <!-- ツイート結果メッセージ（メディア追加ボタンのすぐ隣） -->
                <TextBlock x:Name="OutputTextBlock" 
               Grid.Column="2"
               FontSize="20"
               VerticalAlignment="Center"
               Margin="8,0,12,0"
               Foreground="White"/>

                <!-- 選択中メディア数 -->
                <TextBlock x:Name="SelectedMediaCount" 
               Grid.Column="3"
               VerticalAlignment="Center"
               FontSize="14" 
               Foreground="Gray"
               Margin="4,0,12,0"/>

                <!-- 文字数カウント -->
                <TextBlock x:Name="CountText"
               Grid.Column="4"
               VerticalAlignment="Center"
               HorizontalAlignment="Right"
               Foreground="Gray"
               Text="0 文字"/>

                <!-- ローディングアニメーション -->
                <ProgressRing x:Name="PostingProgressRing"
                  Grid.Column="5"
                  Width="24" Height="24"
                  IsActive="False"
                  Visibility="Collapsed"
                  Margin="8,0,0,0"/>
            </Grid>

            <!-- プレビュー一覧 -->
            <ScrollViewer Height="160" HorizontalScrollBarVisibility="Auto" Margin="0,8,0,0">
                <ItemsControl ItemsSource="{x:Bind SelectedFiles, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="140" Height="140" Margin="4">
                                <Border CornerRadius="8" Background="#1E1E1E" BorderBrush="#555" BorderThickness="2">
                                    <Image Source="{Binding Preview}" Stretch="UniformToFill"/>
                                </Border>
                                <!-- 削除ボタン -->
                                <Button Content="✕" 
                                        Background="#D0000000"
                                        Foreground="White"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Padding="6,2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="6"
                                        Click="RemoveMedia_Click"
                                        Tag="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Page>
