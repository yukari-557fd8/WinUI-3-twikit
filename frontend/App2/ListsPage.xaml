<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App2.ListsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App2"
    xmlns:controls="using:App2.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <local:HasItemsToVisibilityConverter x:Key="HasItemsToVisibilityConverter" />
        <local:LikeColorConverter x:Key="LikeColorConverter" />
        <local:RetweetColorConverter x:Key="RetweetColorConverter" />
        <local:MediaTypeToVisibilityConverter x:Key="MediaTypeToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- パンくず（ツイートページのタイトルと同じ FontSize=24） -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8,0,4,12" VerticalAlignment="Center">
            <TextBlock Text="リスト"
                       FontSize="24"
                       VerticalAlignment="Center"
                       Visibility="{x:Bind ViewModel.ShowListCatalog, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <Button Content="リスト"
                    Click="BreadcrumbList_Click"
                    Style="{StaticResource SubtleButtonStyle}"
                    FontSize="24"
                    Padding="0"
                    MinHeight="0"
                    MinWidth="0"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Visibility="{x:Bind ViewModel.ShowTimeline, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock Text=">"
                       FontSize="24"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind ViewModel.ShowTimeline, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock Text="{x:Bind ViewModel.SelectedListName, Mode=OneWay}"
                       FontSize="24"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Visibility="{x:Bind ViewModel.ShowTimeline, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <!-- 読み込み中 -->
        <ProgressRing Grid.Row="1"
                      Width="60" Height="60"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>

        <!-- リスト一覧 -->
        <ListView Grid.Row="1"
                  x:Name="ListsListView"
                  ItemsSource="{x:Bind ViewModel.Lists, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="ListsListView_ItemClick"
                  Visibility="{x:Bind ViewModel.IsListCatalogContentVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ListItemViewModel">
                    <Border Margin="0,6" Padding="16" CornerRadius="12"
                            Background="#1F1F1F" BorderBrush="#2A2A2A" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Bind Name}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       FontSize="16"/>
                            <TextBlock Text="{x:Bind Description}"
                                       TextWrapping="WrapWholeWords"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxLines="2"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{x:Bind MemberInfo}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind Mode}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- リストタイムライン -->
        <ListView Grid.Row="1"
                  x:Name="TimelineListView"
                  ItemsSource="{x:Bind ViewModel.Tweets, Mode=OneWay}"
                  SelectionMode="None"
                  Visibility="{x:Bind ViewModel.IsTimelineContentVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:TweetViewModel">
                    <Border Margin="0,6" Padding="16" CornerRadius="12"
                            Background="#1F1F1F" BorderBrush="#2A2A2A" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        Visibility="{x:Bind IsRetweet, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon Glyph="&#xE72A;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind RetweetHeaderText, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                            </StackPanel>

                            <controls:TweetUserRow
                                UserName="{x:Bind UserName}"
                                UserScreenName="{x:Bind UserScreenName}"
                                CreatedAtAbsoluteDisplay="{x:Bind CreatedAtAbsoluteDisplay, Mode=OneWay}"
                                CreatedAtRelativeDisplay="{x:Bind CreatedAtRelativeDisplay, Mode=OneWay}"
                                UserProfileImage="{x:Bind UserProfileImage, Mode=OneWay}"/>

                            <TextBlock Text="{x:Bind Text}"
                                       TextWrapping="WrapWholeWords"
                                       FontSize="15"
                                       LineHeight="20"
                                       Visibility="{x:Bind HasText, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <ItemsControl ItemsSource="{x:Bind MediaItems, Mode=OneWay}"
                                          Visibility="{x:Bind HasOuterMedia, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:MediaItem">
                                        <Border CornerRadius="8" Background="#1A1A1A" Margin="0,4" MaxWidth="320">
                                            <Grid>
                                                <Image Source="{x:Bind ThumbnailImage, Mode=OneTime}"
                                                       Tag="{x:Bind Url, Mode=OneTime}"
                                                       Stretch="Uniform"
                                                       MaxHeight="260"
                                                       HorizontalAlignment="Center"
                                                       Tapped="MediaThumbnail_Tapped"/>
                                                <Border Background="#80000000"
                                                        CornerRadius="32"
                                                        Width="64" Height="64"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        IsHitTestVisible="False"
                                                        Visibility="{x:Bind Type, Converter={StaticResource MediaTypeToVisibilityConverter}, ConverterParameter=video}">
                                                    <FontIcon Glyph="&#xE768;" FontSize="28" Foreground="White"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <controls:QuotedTweetCard Tweet="{x:Bind Mode=OneWay}"/>

                            <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Left" Margin="0,8,0,0">
                                <Button Style="{StaticResource SubtleButtonStyle}" Click="ReplyButton_Click" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8BD;" FontSize="18"/>
                                        <TextBlock Text="{x:Bind ReplyCount}"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SubtleButtonStyle}" Click="RetweetButton_Click" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE72A;" FontSize="18" Foreground="{x:Bind IsRetweeted, Converter={StaticResource RetweetColorConverter}, Mode=OneWay}"/>
                                        <TextBlock Text="{x:Bind RetweetCount, Mode=OneWay}"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SubtleButtonStyle}" Click="LikeButton_Click" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xEB51;" FontSize="18" Foreground="{x:Bind IsLiked, Converter={StaticResource LikeColorConverter}, Mode=OneWay}"/>
                                        <TextBlock Text="{x:Bind FavoriteCount, Mode=OneWay}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <StackPanel Visibility="{x:Bind IsReplying, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Tag="{x:Bind ReplyOwner, Mode=OneWay}"
                                        PreviewKeyDown="ReplyForm_PreviewKeyDown"
                                        Spacing="8" Margin="0,8,0,0">
                                <TextBox Text="{x:Bind ReplyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="返信を入力..."
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MaxHeight="120"
                                         VerticalAlignment="Top"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="返信" Click="SendReply_Click" Style="{StaticResource AccentButtonStyle}"
                                            IsEnabled="{x:Bind IsReplySendEnabled, Mode=OneWay}"/>
                                    <ProgressRing Width="24" Height="24"
                                                  IsActive="{x:Bind IsReplySending, Mode=OneWay}"
                                                  Visibility="{x:Bind IsReplySending, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  VerticalAlignment="Center"/>
                                    <Button Content="キャンセル" Click="CancelReply_Click"
                                            IsEnabled="{x:Bind IsReplySendEnabled, Mode=OneWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
