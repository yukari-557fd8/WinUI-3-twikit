<Page
    x:Class="App2.MyProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <!-- 中央寄せコンテナ -->
        <StackPanel 
            Spacing="20" 
            MaxWidth="1100" 
            HorizontalAlignment="Center"
            VerticalAlignment="Top">

            <!-- ヘッダー（バナー＋アイコン） -->
            <Grid Height="180" Margin="0,0,0,8">
                <Image x:Name="BannerImage" Stretch="UniformToFill" />
                <Border Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" 
                        VerticalAlignment="Bottom" Height="80" Opacity="0.85"/>

                <PersonPicture x:Name="ProfilePicture" 
                               Width="120" Height="120"
                               Margin="24" VerticalAlignment="Bottom" />
            </Grid>

            <!-- 基本情報 -->
            <StackPanel Margin="24,0" Spacing="4">
                <TextBlock x:Name="DisplayNameText" 
                           Style="{StaticResource TitleLargeTextBlockStyle}" />

                <TextBlock x:Name="HandleText" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="18" />

                <TextBlock x:Name="BioText" 
                           TextWrapping="WrapWholeWords" 
                           Margin="0,12,0,16" />
            </StackPanel>

            <!-- 統計 -->
            <Grid Margin="24,0" ColumnSpacing="48" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:Name="TweetsCount" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="24"/>
                    <TextBlock Text="ポスト" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock x:Name="FollowingCount" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="24"/>
                    <TextBlock Text="フォロー中" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="FollowersCount" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="24"/>
                    <TextBlock Text="フォロワー" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <!-- その他の情報 -->
            <StackPanel Margin="24,16,24,0" Spacing="8">
                <TextBlock x:Name="LocationText" />
                <TextBlock x:Name="WebsiteText" />
                <TextBlock x:Name="JoinedText" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
