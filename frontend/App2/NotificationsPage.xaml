<Page
    x:Class="App2.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="12">
        <!-- 読み込み中 -->
        <ProgressRing
            Width="60" Height="60"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsIndeterminate="True"/>

        <!-- 通知リスト -->
        <ListView ItemsSource="{x:Bind ViewModel.Notifications, Mode=OneWay}"
                  SelectionMode="None"
                  Padding="8"
                  x:Name="NotificationsListView"
                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:NotificationViewModel">
                    <Border Margin="0,6" Padding="16" CornerRadius="12"
                            Background="#1F1F1F" BorderBrush="#2A2A2A" BorderThickness="1">

                        <StackPanel Spacing="12">
                            <!-- 通知タイプ/ユーザー -->
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <PersonPicture Width="48" Height="48" ProfilePicture="{x:Bind ActorProfileImage, Mode=OneWay}"/>

                                <!-- 名前 + スクリーンネーム + 日時 -->
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind ActorName}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   FontSize="15"/>
                                        <TextBlock Text="{x:Bind ActorScreenName}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind CreatedAtDisplay, Mode=OneWay}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </StackPanel>

                            <!-- 通知本文 -->
                            <TextBlock Text="{x:Bind Text}" TextWrapping="WrapWholeWords" FontSize="15" LineHeight="20"/>

                            <!-- 対象ツイート -->
                            <Border Visibility="{x:Bind HasTargetTweet, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="#252525" CornerRadius="8" Padding="12">
                                <TextBlock Text="{x:Bind TargetTweetText}" TextWrapping="Wrap" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
